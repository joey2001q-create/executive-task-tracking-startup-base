#!/usr/bin/env python3
"""
feishu-data-collector-v3 - collect Feishu data with user_access_token
stored in the external member token Bitable.
"""
import datetime
import json
import os
import sys
import time

import requests


FEISHU_API = "https://open.feishu.cn"


def required_env(*names):
    for name in names:
        value = os.environ.get(name)
        if value:
            return value
    raise RuntimeError(f"missing required env: {'/'.join(names)}")


BASE_TOKEN = required_env("FEISHU_TOKEN_BASE_TOKEN", "FEISHU_BASE_TOKEN", "AGENT_BASE_TOKEN")
TABLE_ID = required_env("FEISHU_TOKEN_TABLE_ID", "FEISHU_TABLE_ID")
APP_ID = required_env("LARK_APP_ID", "FEISHU_APP_ID")
APP_SECRET = required_env("LARK_APP_SECRET", "FEISHU_APP_SECRET")


def get_bot_token():
    resp = requests.post(
        f"{FEISHU_API}/open-apis/auth/v3/tenant_access_token/internal",
        json={"app_id": APP_ID, "app_secret": APP_SECRET},
        timeout=30,
    )
    data = resp.json()
    if data.get("code") not in (0, None):
        raise RuntimeError(f"tenant token failed: {data.get('msg')}")
    token = data.get("tenant_access_token")
    if not token:
        raise RuntimeError("tenant token response did not include tenant_access_token")
    return token


def extract_text_field(value):
    if isinstance(value, str):
        return value
    if isinstance(value, list) and value:
        first = value[0]
        if isinstance(first, dict):
            return first.get("text", "")
        return str(first)
    return str(value) if value else ""


def get_token_from_base(open_id):
    bot_token = get_bot_token()
    url = f"{FEISHU_API}/open-apis/bitable/v1/apps/{BASE_TOKEN}/tables/{TABLE_ID}/records/search"
    headers = {"Authorization": f"Bearer {bot_token}", "Content-Type": "application/json"}
    payload = {
        "filter": {
            "conjunction": "and",
            "conditions": [
                {"field_name": "成员", "operator": "is", "value": [open_id]}
            ],
        },
        "page_size": 10,
    }
    resp = requests.post(url, headers=headers, json=payload, timeout=30)
    data = resp.json()
    if data.get("code") != 0:
        print(f"token table query failed: {data.get('msg')}", file=sys.stderr)
        return None

    items = data.get("data", {}).get("items", [])
    if not items:
        print(f"token table has no row for {open_id}", file=sys.stderr)
        return None

    token = extract_text_field(items[0].get("fields", {}).get("user_access_token", ""))
    if not token or token == "None":
        print(f"user_access_token is empty for {open_id}", file=sys.stderr)
        return None
    return token


def api_call(token, method, endpoint, params=None, json_data=None):
    url = f"{FEISHU_API}{endpoint}"
    headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
    try:
        if method.upper() == "GET":
            resp = requests.get(url, headers=headers, params=params, timeout=60)
        elif method.upper() == "POST":
            resp = requests.post(url, headers=headers, json=json_data, params=params, timeout=60)
        else:
            return {"ok": False, "error": f"unsupported method: {method}"}
        data = resp.json()
        data["ok"] = data.get("code") == 0
        return data
    except Exception as exc:
        return {"ok": False, "error": str(exc)}


def iso_to_timestamp(iso_str):
    dt = datetime.datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
    return int(dt.timestamp())


def collect_all_pages(token, method, endpoint, initial_params=None, initial_json=None, items_key="items", max_pages=20):
    all_items = []
    page_token = None
    page_count = 0
    while page_count < max_pages:
        params = dict(initial_params) if initial_params else {}
        json_data = dict(initial_json) if initial_json else None
        if page_token:
            params["page_token"] = page_token

        result = api_call(token, method, endpoint, params=params, json_data=json_data)
        if not result.get("ok"):
            result["_collected_items"] = all_items
            result["_pages"] = page_count
            return result

        data = result.get("data", {})
        all_items.extend(data.get(items_key, []))
        page_count += 1
        page_token = data.get("page_token")
        if not data.get("has_more") or not page_token:
            break
        time.sleep(0.5)

    return {
        "ok": True,
        "code": 0,
        "data": {
            items_key: all_items,
            "has_more": False,
            "page_token": None,
            "_total_pages": page_count,
            "_total_items": len(all_items),
        },
    }


def collect_calendar(token, start_iso, end_iso):
    params = {
        "start_time": iso_to_timestamp(start_iso),
        "end_time": iso_to_timestamp(end_iso),
        "page_size": 100,
    }
    return api_call(token, "GET", "/open-apis/calendar/v4/calendars/primary/events/instance_view", params=params)


def collect_task(token):
    params = {"user_id_type": "open_id", "page_size": 100, "type": "my_tasks"}
    return collect_all_pages(token, "GET", "/open-apis/task/v2/tasks", initial_params=params)


def collect_minutes(token, start_iso, end_iso):
    payload = {
        "filter": {
            "create_time": {"start_time": start_iso, "end_time": end_iso}
        },
        "page_size": 100,
    }
    return api_call(token, "POST", "/open-apis/minutes/v1/minutes/search", json_data=payload)


def collect_messages(token, start_iso, end_iso, chat_type):
    payload = {
        "query": "",
        "filter": {
            "time_range": {"start_time": start_iso, "end_time": end_iso},
            "chat_type": chat_type,
        },
    }
    params = {"page_size": 30, "user_id_type": "open_id"}
    return collect_all_pages(
        token,
        "POST",
        "/open-apis/im/v1/messages/search",
        initial_params=params,
        initial_json=payload,
        items_key="items",
    )


def collect_mail(token):
    params = {"label_id": "INBOX", "page_size": 20}
    return collect_all_pages(
        token,
        "GET",
        "/open-apis/mail/v1/user_mailboxes/me/messages",
        initial_params=params,
        items_key="items",
        max_pages=10,
    )


def collect_user(open_id, name, start_iso, end_iso):
    result = {"user": name, "open_id": open_id, "period": f"{start_iso} ~ {end_iso}", "sources": {}}
    print(f"loading user token for {name}...", file=sys.stderr)
    token = get_token_from_base(open_id)
    if not token:
        result["sources"]["_error"] = "cannot load user_access_token from token table"
        return result

    result["sources"]["calendar"] = collect_calendar(token, start_iso, end_iso)
    time.sleep(1)
    result["sources"]["task"] = collect_task(token)
    time.sleep(1)
    result["sources"]["minutes"] = collect_minutes(token, start_iso, end_iso)
    time.sleep(1)
    result["sources"]["group"] = collect_messages(token, start_iso, end_iso, "group")
    time.sleep(1)
    result["sources"]["p2p"] = collect_messages(token, start_iso, end_iso, "p2p")
    time.sleep(1)
    result["sources"]["mail"] = collect_mail(token)
    return result


def main():
    if len(sys.argv) < 3:
        print("Usage: feishu-data-collector-v3 <output.json> <open_id:name> [<open_id:name> ...]", file=sys.stderr)
        sys.exit(1)

    output = sys.argv[1]
    users = []
    for raw_user in sys.argv[2:]:
        open_id, name = raw_user.split(":", 1)
        users.append((open_id, name))

    end = time.strftime("%Y-%m-%dT23:59:59+08:00", time.localtime())
    start = time.strftime("%Y-%m-%dT00:00:00+08:00", time.localtime(time.time() - 7 * 86400))
    all_data = {"period": {"start": start, "end": end}, "executives": []}

    for open_id, name in users:
        all_data["executives"].append(collect_user(open_id, name, start, end))
        time.sleep(2)

    with open(output, "w", encoding="utf-8") as handle:
        json.dump(all_data, handle, indent=2, ensure_ascii=False)


if __name__ == "__main__":
    main()
