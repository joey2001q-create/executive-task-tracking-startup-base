#!/usr/bin/env python3
"""Collect Feishu calendar events for an authorized user."""
import argparse
import datetime
import json
import os
import sys

import requests


FEISHU_API = "https://open.feishu.cn"


def required_env(*names):
    for name in names:
        value = os.environ.get(name)
        if value:
            return value
    raise RuntimeError(f"missing required env: {'/'.join(names)}")


APP_ID = required_env("LARK_APP_ID", "FEISHU_APP_ID")
APP_SECRET = required_env("LARK_APP_SECRET", "FEISHU_APP_SECRET")
BASE_TOKEN = required_env("FEISHU_TOKEN_BASE_TOKEN", "FEISHU_BASE_TOKEN", "AGENT_BASE_TOKEN")
TABLE_ID = required_env("FEISHU_TOKEN_TABLE_ID", "FEISHU_TABLE_ID")


def get_tenant_token():
    resp = requests.post(
        f"{FEISHU_API}/open-apis/auth/v3/tenant_access_token/internal",
        json={"app_id": APP_ID, "app_secret": APP_SECRET},
        timeout=30,
    )
    return resp.json().get("tenant_access_token")


def extract_text_field(value):
    if isinstance(value, str):
        return value
    if isinstance(value, list) and value:
        first = value[0]
        if isinstance(first, dict):
            return first.get("text", "")
        return str(first)
    return str(value) if value else ""


def get_user_token(open_id):
    tenant_token = get_tenant_token()
    url = f"{FEISHU_API}/open-apis/bitable/v1/apps/{BASE_TOKEN}/tables/{TABLE_ID}/records/search"
    headers = {"Authorization": f"Bearer {tenant_token}", "Content-Type": "application/json"}
    payload = {
        "filter": {"conjunction": "and", "conditions": [{"field_name": "成员", "operator": "is", "value": [open_id]}]},
        "page_size": 10,
    }
    data = requests.post(url, headers=headers, json=payload, timeout=30).json()
    items = data.get("data", {}).get("items", []) if data.get("code") == 0 else []
    if not items:
        return None
    token = extract_text_field(items[0].get("fields", {}).get("user_access_token", ""))
    return token if len(token) > 100 else None


def iso_to_timestamp(value):
    return int(datetime.datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp())


def collect_calendar(user_open_id, start_time, end_time):
    token = get_user_token(user_open_id)
    if not token:
        return {"ok": False, "error": "cannot load user_access_token", "source": "calendar", "user": user_open_id, "count": 0, "items": []}

    headers = {"Authorization": f"Bearer {token}"}
    params = {
        "start_time": iso_to_timestamp(start_time),
        "end_time": iso_to_timestamp(end_time),
        "page_size": 1000,
    }
    url = f"{FEISHU_API}/open-apis/calendar/v4/calendars/primary/events"
    result = requests.get(url, headers=headers, params=params, timeout=60).json()
    items = result.get("data", {}).get("items", []) if result.get("code") == 0 else []
    return {"ok": result.get("code") == 0, "source": "calendar", "user": user_open_id, "count": len(items), "items": items, "raw": result}


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--user", required=True)
    parser.add_argument("--start", required=True)
    parser.add_argument("--end", required=True)
    parser.add_argument("--output")
    args = parser.parse_args()

    result = collect_calendar(args.user, args.start, args.end)
    output = json.dumps(result, ensure_ascii=False)
    if args.output:
        with open(args.output, "w", encoding="utf-8") as handle:
            handle.write(output)
    else:
        print(output)


if __name__ == "__main__":
    main()
