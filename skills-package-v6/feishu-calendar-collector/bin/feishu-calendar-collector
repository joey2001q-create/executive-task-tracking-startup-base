#!/usr/bin/env python3
"""
飞书日程数据采集器（Python版）
直接从多维表获取token，避免shell变量截断问题
"""
import sys, os, json, argparse, requests

def required_env(*names):
    for name in names:
        value = os.environ.get(name)
        if value:
            return value
    raise RuntimeError(f"missing required env: {'/'.join(names)}")

APP_ID = required_env("LARK_APP_ID", "FEISHU_APP_ID")
APP_SECRET = required_env("LARK_APP_SECRET", "FEISHU_APP_SECRET")
BASE_TOKEN = required_env("FEISHU_TOKEN_BASE_TOKEN", "FEISHU_BASE_TOKEN", "AGENT_BASE_TOKEN")
TABLE_ID = required_env("FEISHU_TOKEN_TABLE_ID", "FEISHU_TABLE_ID")

def get_tenant_token():
    r = requests.post("https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal",
        json={"app_id": APP_ID, "app_secret": APP_SECRET})
    return r.json().get("tenant_access_token")

def get_user_token(open_id):
    """从多维表获取用户token（安全方式，避免shell截断）"""
    tenant_token = get_tenant_token()
    url = f"https://open.feishu.cn/open-apis/bitable/v1/apps/{BASE_TOKEN}/tables/{TABLE_ID}/records/search"
    headers = {"Authorization": f"Bearer {tenant_token}", "Content-Type": "application/json"}
    payload = {
        "filter": {"conjunction": "and", "conditions": [
            {"field_name": "成员", "operator": "is", "value": [open_id]}
        ]},
        "page_size": 10
    }
    r = requests.post(url, headers=headers, json=payload)
    data = r.json()
    if data.get("code") == 0:
        items = data.get("data", {}).get("items", [])
        if items:
            fields = items[0].get("fields", {})
            token_field = fields.get("user_access_token", "")
            token = ""
            if isinstance(token_field, list) and len(token_field) > 0:
                if isinstance(token_field[0], dict):
                    token = token_field[0].get("text", "")
            elif isinstance(token_field, str):
                token = token_field
            if len(token) > 100:
                return token
    return None

def collect_calendar(user_open_id, start_time, end_time):
    """采集日程"""
    token = get_user_token(user_open_id)
    if not token:
        return {"ok": False, "error": "无法获取用户token", "source": "calendar", "user": user_open_id, "count": 0, "items": []}

    headers = {"Authorization": f"Bearer {token}"}
    
    # 先获取日历ID列表
    r = requests.get("https://open.feishu.cn/open-apis/calendar/v4/calendars", headers=headers)
    cal_result = r.json()
    
    all_events = []
    if cal_result.get("code") == 0:
        calendars = cal_result.get("data", {}).get("calendar_list", [])
        if not calendars:
            # 默认使用primary
            calendars = [{"calendar_id": "primary"}]
        
        for cal in calendars:
            cal_id = cal.get("calendar_id", "primary")
            # 转换时间格式
            try:
                import datetime
                start_dt = datetime.datetime.fromisoformat(start_time.replace('Z', '+00:00'))
                end_dt = datetime.datetime.fromisoformat(end_time.replace('Z', '+00:00'))
                time_min = int(start_dt.timestamp())
                time_max = int(end_dt.timestamp())
            except:
                time_min = 0
                time_max = 9999999999
            
            events_url = f"https://open.feishu.cn/open-apis/calendar/v4/calendars/{cal_id}/events?time_min={time_min}&time_max={time_max}&page_size=500"
            r = requests.get(events_url, headers=headers)
            ev_result = r.json()
            if ev_result.get("code") == 0:
                for ev in ev_result.get("data", {}).get("items", []):
                    ev["calendar_id"] = cal_id
                    all_events.append(ev)
    
    return {
        "ok": True,
        "source": "calendar",
        "user": user_open_id,
        "count": len(all_events),
        "items": all_events
    }

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--user", required=True)
    parser.add_argument("--start", required=True)
    parser.add_argument("--end", required=True)
    parser.add_argument("--output")
    args = parser.parse_args()

    result = collect_calendar(args.user, args.start, args.end)
    output = json.dumps(result, ensure_ascii=False)
    
    if args.output:
        with open(args.output, "w") as f:
            f.write(output)
    else:
        print(output)

if __name__ == "__main__":
    main()
