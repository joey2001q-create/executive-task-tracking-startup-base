#!/usr/bin/env python3
"""Collect Feishu mail message IDs for an authorized user."""
import argparse
import json
import os
import time

import requests


FEISHU_API = "https://open.feishu.cn"


def required_env(*names):
    for name in names:
        value = os.environ.get(name)
        if value:
            return value
    raise RuntimeError(f"missing required env: {'/'.join(names)}")


APP_ID = required_env("LARK_APP_ID", "FEISHU_APP_ID")
APP_SECRET = required_env("LARK_APP_SECRET", "FEISHU_APP_SECRET")
BASE_TOKEN = required_env("FEISHU_TOKEN_BASE_TOKEN", "FEISHU_BASE_TOKEN", "AGENT_BASE_TOKEN")
TABLE_ID = required_env("FEISHU_TOKEN_TABLE_ID", "FEISHU_TABLE_ID")


def get_tenant_token():
    return requests.post(
        f"{FEISHU_API}/open-apis/auth/v3/tenant_access_token/internal",
        json={"app_id": APP_ID, "app_secret": APP_SECRET},
        timeout=30,
    ).json().get("tenant_access_token")


def extract_text_field(value):
    if isinstance(value, str):
        return value
    if isinstance(value, list) and value:
        first = value[0]
        if isinstance(first, dict):
            return first.get("text", "")
        return str(first)
    return str(value) if value else ""


def get_user_token(open_id):
    url = f"{FEISHU_API}/open-apis/bitable/v1/apps/{BASE_TOKEN}/tables/{TABLE_ID}/records/search"
    headers = {"Authorization": f"Bearer {get_tenant_token()}", "Content-Type": "application/json"}
    payload = {
        "filter": {"conjunction": "and", "conditions": [{"field_name": "成员", "operator": "is", "value": [open_id]}]},
        "page_size": 10,
    }
    data = requests.post(url, headers=headers, json=payload, timeout=30).json()
    items = data.get("data", {}).get("items", []) if data.get("code") == 0 else []
    if not items:
        return None
    token = extract_text_field(items[0].get("fields", {}).get("user_access_token", ""))
    return token if len(token) > 100 else None


def collect_mail(user_open_id, label_id="INBOX"):
    token = get_user_token(user_open_id)
    if not token:
        return {"ok": False, "error": "cannot load user_access_token", "source": "mail", "user": user_open_id, "count": 0, "items": []}

    headers = {"Authorization": f"Bearer {token}"}
    all_items = []
    page_token = None

    for _ in range(10):
        params = {"label_id": label_id, "page_size": 20}
        if page_token:
            params["page_token"] = page_token
        resp = requests.get(
            f"{FEISHU_API}/open-apis/mail/v1/user_mailboxes/me/messages",
            headers=headers,
            params=params,
            timeout=60,
        )
        if not resp.headers.get("Content-Type", "").startswith("application/json"):
            break
        result = resp.json()
        if result.get("code") != 0:
            return {"ok": False, "source": "mail", "user": user_open_id, "count": len(all_items), "items": all_items, "raw": result}
        data = result.get("data", {})
        all_items.extend(data.get("items", []))
        page_token = data.get("page_token")
        if not data.get("has_more") or not page_token:
            break
        time.sleep(0.5)

    return {"ok": True, "source": "mail", "user": user_open_id, "count": len(all_items), "items": all_items}


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--user", required=True)
    parser.add_argument("--label-id", default="INBOX")
    parser.add_argument("--output")
    args = parser.parse_args()

    result = collect_mail(args.user, args.label_id)
    output = json.dumps(result, ensure_ascii=False)
    if args.output:
        with open(args.output, "w", encoding="utf-8") as handle:
            handle.write(output)
    else:
        print(output)


if __name__ == "__main__":
    main()
